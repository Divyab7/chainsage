  "scoring_rules": {
    "derivatives": {
      "bullish": "funding_rate > 0.01% AND price > ema_21",
      "bearish": "funding_rate < -0.01% OR price < ema_21 * 0.98",
      "neutral": "otherwise"
    },
    "on_chain": {
      "bullish": "holder_change_7d > 2%",
      "bearish": "holder_change_7d < -1%"
    },
    "narrative": {
      "bullish": "sector_rank <= 10 AND fng >= 40",
      "bearish": "fng < 20 OR sector_rank > 50"
    }
  },
  "conviction_formula": "conviction = (sum(layer_scores) + 1) / 4, clamped to [0, 1]",
  "exposure_formula": "target_exposure = conviction * 0.8 when signal=long",
  "standard_falsifiers": [
    "fng < 20",
    "funding_rate > 0.05%",
    "holder_distribution_concentration > 0.6",
    "narrative_momentum < -0.3"
  ],
